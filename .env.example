# Environment variables for Docker Compose
# Copy this file to .env and update with your values

# MySQL Configuration
MYSQL_ROOT_PASSWORD=FreelanceHub@2026!
MYSQL_DATABASE=freelancehub_db
MYSQL_USER=freelancehub_user
MYSQL_PASSWORD=FreelanceHub@User2026!

# Redis Configuration
REDIS_PASSWORD=FreelanceHub@Redis2026!

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
JWT_SECRET_KEY=YourSuperSecretKeyThatIsAtLeast32CharactersLongForProduction!

# Email Configuration (Optional)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=noreply@freelancehub.com
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
